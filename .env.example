# Burp Suite Connection Configuration
BURP_HOST=localhost
BURP_PORT=1337
BURP_API_KEY=
BURP_USE_HTTPS=False
# Edition: community or professional (default: community)
BURP_EDITION=community

# Agent Settings
VERBOSE_MODE=True

# AI Model Provider Configuration
# Options: local (default), ollama, huggingface
MODEL_PROVIDER=local

# Ollama Configuration (for local LLM models)
OLLAMA_MODEL=llama2
OLLAMA_HOST=localhost
OLLAMA_PORT=11434

# HuggingFace Configuration (for cloud-based models)
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.1
HF_API_KEY=your_huggingface_api_key_here

# System Prompt Configuration
# Options: security_analyzer (default), owasp_expert, api_security, compliance_checker, developer_focused, pentest_report
SYSTEM_PROMPT=security_analyzer
# Alternatively, set a custom system prompt directly (overrides SYSTEM_PROMPT)
CUSTOM_SYSTEM_PROMPT=
